{
  "name": "crowdspark-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev:demo": "tsx src/demo.ts",
    "migrate:financial-security": "tsx src/scripts/migrate-financial-security.ts",
    "migrate:auth-rbac": "tsx src/scripts/migrate-auth-rbac.ts",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts' --exclude '**/financial.service.test.ts'",
    "test:integration": "vitest run src/modules/admin/auth-rbac.integration.test.ts src/modules/financial/financial.service.test.ts",
    "test:coverage": "vitest run --coverage --exclude \"**/*.integration.test.ts\" --exclude \"**/financial.service.test.ts\"",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@better-auth/mongo-adapter": "^1.6.0",
    "better-auth": "^1.6.0",
    "cors": "^2.8.5",
    "crowdspark-fullstack": "file:..",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "stripe": "^18.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.7.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "mongodb-memory-server": "^10.2.3",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
